# Casual Editor — environment configuration template.
#
# Copy to `.env` and fill in. The bundled Docker image picks safe
# defaults for every variable below; you only need to override the
# values that apply to your deployment.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose --env-file .env up
#
# Variables are grouped by which layer reads them.

# ─── Collab server (Node CasualOffice/collab) ──────────────────────
# The bundled image runs the collab server, which serves the SPA, the
# REST surface (/api/rooms, /auth, /files, /wopi), and the Hocuspocus
# WS broker (/yjs) all on one origin. Full reference + the Mode 2/3
# (WOPI / personal-auth) tunables: docs/internal/12-env-vars.md.

# Port the server binds to (the bundled image defaults to 8080).
# PORT=8080

# Room Y.Doc persistence: in-memory (default; rooms drain on
# disconnect) | local | redis. `local` needs a /data volume.
# CASUAL_STORAGE=local
# CASUAL_LOCAL_PATH=/data

# File-byte host backend for Mode 2/3: memory | local | s3 | postgres.
# CASUAL_FILE_EXT=.docx

# Personal-auth (Mode 3): none (default) | single | multi.
# CASUAL_PERSONAL_MODE=multi


# ─── Editor build (Vite, read at build time) ───────────────────────

# Collab WS endpoint the editor connects to. The /api/rooms REST base
# is derived from this same origin. Leave unset for the bundled image
# (same-origin /yjs is correct). Set in dev when Vite is on :5173 and
# the collab server on :1234.
# VITE_COLLAB_BACKEND=ws://localhost:1234/yjs

# Toggle the Share button. The Pages demo builds with this off because
# there's no collab server behind doc.schnsrw.live. The Docker image
# build sets this to "true".
VITE_COLLAB_ENABLED=true


# ─── Fidelity comparison harness ───────────────────────────────────
# Only consumed by scripts/compare-fidelity.mjs + the
# fidelity-compare.yml CI workflow. Safe to leave commented out
# in normal use.

# Pristine-share floor (0–1). The harness fails the run when our
# pristine fraction drops below this. Raise as gap-matrix items
# close.
# Default: 0.5
# FIDELITY_FLOOR=0.5

# Path to `soffice` if not on PATH. Harness probes a few defaults.
# LIBREOFFICE_BIN=/Applications/LibreOffice.app/Contents/MacOS/soffice

# Override the Docker image tag for OnlyOffice DocumentBuilder.
# Default: onlyoffice/documentbuilder:latest
# ONLYOFFICE_DOCBUILDER_IMAGE=onlyoffice/documentbuilder:7.5.0
